# .env - Praxida 2.0 Erweiterte Konfiguration

# Neue Multi-Tenancy Einstellungen hinzufügen:

NODE_ENV=development
DATABASE_PATH=./data/praxida.db

# === SERVER KONFIGURATION === #
PORT=3000
NODE_ENV=development

# === DATENBANK === #
DATABASE_PATH=./data/praxida.db

# === FILE UPLOAD === #
UPLOAD_DIR=uploads
AUDIO_UPLOAD_DIR=uploads/audio
MAX_FILE_SIZE=104857600
MAX_AUDIO_SIZE=104857600

# === WHISPER KONFIGURATION === #
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=de
WHISPER_TEMPERATURE=0

# === KI-CHAT KONFIGURATION === #
GPT_MODEL=gpt-3.5-turbo
GPT_MAX_TOKENS=2000
GPT_TEMPERATURE=0.7


# === DSGVO COMPLIANCE === #
DATA_RETENTION_DAYS=2555
BACKUP_ENABLED=true
ANONYMIZE_EXPORTS=true

# === LOGGING === #
DEBUG=false
LOG_LEVEL=info

# === OPTIONAL: WEITERE KI-FEATURES === #
# ENABLE_VISION_API=false
# ENABLE_TEXT_TO_SPEECH=false
# ENABLE_DALL_E=false
